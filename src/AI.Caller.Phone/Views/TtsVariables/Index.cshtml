@model IEnumerable<AI.Caller.Phone.Entities.TtsVariable>

@{
    ViewData["Title"] = "TTS变量管理";
}

<div class="container mt-4">
    <div class="row align-items-center">
        <div class="col d-flex">
            <div class="page-icon me-3">
                <i class="bi bi-opencollective"></i>
            </div>
            <div class="col-auto">
                <h2>@ViewData["Title"]</h2>
            </div>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">创建新变量</a>
        </div>
    </div>
    <hr />

    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">变量列表</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Description)</th>
                        <th>使用计数</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td><code>@Html.DisplayFor(modelItem => item.Name)</code></td>
                        <td>@Html.DisplayFor(modelItem => item.Description)</td>
                        <td>
                            <span class="badge bg-primary rounded-pill">@item.TtsTemplates.Count</span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash me-1"></i></a>
                            </div>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>

</div>
