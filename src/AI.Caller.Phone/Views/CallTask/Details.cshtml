@model AI.Caller.Phone.Entities.BatchCallJob

@{
    ViewData["Title"] = "任务详情";
}

<div class="container mt-4">
    <div class="row align-items-center">
        <div class="col d-flex">
            <div class="page-icon me-3">
                <i class="bi bi-phone-vibrate"></i>
            </div>
            <div class="col-auto">
                <h2>@ViewData["Title"]: @Model.JobName - 批量呼叫任务</h2>
            </div>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary glass-effect">
                <i class="bi bi-arrow-left me-2"></i>返回
            </a>
        </div>
    </div>

    <hr />

    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Status)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-2">进度</dt>
        <dd class="col-sm-10">
            @if (Model.TotalCount > 0) {
                var progress = (int)Math.Round((double)Model.ProcessedCount * 100 / Model.TotalCount);
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @progress%;" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">@Model.ProcessedCount / @Model.TotalCount</div>
                </div>
                <div>
                    <span class="text-success">成功: @Model.SuccessCount</span> |
                    <span class="text-danger">失败: @Model.FailedCount</span>
                </div>
            } else {
                <span>N/A</span>
            }
        </dd>

        <dt class="col-sm-2">使用模板/场景</dt>
        <dd class="col-sm-10">
            @if (Model.TtsTemplate != null) {
                <span>TTS模板: @Model.TtsTemplate.Name</span>
            } else if (Model.ScenarioRecording != null) {
                <span>场景录音: @Model.ScenarioRecording.Name</span>
            } else {
                <span>无</span>
            }
        </dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OriginalFileName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OriginalFileName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CreatedAt)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.CompletedAt)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CompletedAt)</dd>
    </dl>
    @if (Model.Status == AI.Caller.Phone.Entities.BatchJobStatus.CompletedWithFailures || Model.FailedCount > 0) {
        <form asp-action="RetryFailed" asp-route-id="@Model.Id" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">重试所有失败项</button>
        </form>
    }


    <h4>呼叫记录</h4>
    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.CallLogs.First().CalleeNumber)</th>
                <th>@Html.DisplayNameFor(model => model.CallLogs.First().Status)</th>
                <th>@Html.DisplayNameFor(model => model.CallLogs.First().FailureReason)</th>
                <th>@Html.DisplayNameFor(model => model.CallLogs.First().CreatedAt)</th>
                <th>@Html.DisplayNameFor(model => model.CallLogs.First().CompletedAt)</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.CallLogs.OrderByDescending(l => l.CreatedAt)) {
                <tr>
                    <td>@Html.DisplayFor(modelItem => log.CalleeNumber)</td>
                    <td>@Html.DisplayFor(modelItem => log.Status)</td>
                    <td>@Html.DisplayFor(modelItem => log.FailureReason)</td>
                    <td>@Html.DisplayFor(modelItem => log.CreatedAt)</td>
                    <td>@Html.DisplayFor(modelItem => log.CompletedAt)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#details-@log.Id" aria-expanded="false">
                            <i class="bi bi-chevron-down"></i> 详情
                        </button>
                    </td>
                </tr>
                <tr>
                    <td colspan="6" class="p-0">
                        <div class="collapse" id="details-@log.Id">
                            <div class="card border-top-0">
                                <!-- DTMF输入记录 -->
                                <div class="card-header bg-dark text-light">
                                    <h5 class="mb-0">
                                        <i class="bi bi-keyboard me-2"></i>DTMF输入记录
                                        <span class="badge bg-primary float-end">@log.DtmfInputs.Count 条</span>
                                    </h5>
                                </div>
                                <div class="card-body">
                                    @if (log.DtmfInputs.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-dark table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>输入值</th>
                                                        <th>时间</th>
                                                        <th>有效性</th>
                                                        <th>重试次数</th>
                                                        <th>持续时间(ms)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var input in log.DtmfInputs)
                                                    {
                                                        <tr>
                                                            <td>@input.InputValue</td>
                                                            <td>@input.InputTime.ToString("HH:mm:ss")</td>
                                                            <td>
                                                                <span class="badge @(input.IsValid ? "bg-success" : "bg-danger")">
                                                                    @(input.IsValid ? "有效" : "无效")
                                                                </span>
                                                            </td>
                                                            <td>@input.RetryCount</td>
                                                            <td>@input.Duration</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info">
                                            <i class="bi bi-info-circle me-2"></i>无DTMF输入记录
                                        </div>
                                    }
                                </div>

                                <!-- 监控会话 -->
                                <div class="card-header bg-dark text-light">
                                    <h5 class="mb-0">
                                        <i class="bi bi-shield me-2"></i>监控会话
                                        <span class="badge bg-info float-end">@log.MonitoringSessions.Count 条</span>
                                    </h5>
                                </div>
                                <div class="card-body">
                                    @if (log.MonitoringSessions.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-dark table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>监控者</th>
                                                        <th>开始时间</th>
                                                        <th>结束时间</th>
                                                        <th>状态</th>
                                                        <th>接入情况</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var session in log.MonitoringSessions)
                                                    {
                                                        <tr>
                                                            <td>@session.MonitorUserName</td>
                                                            <td>@session.StartTime.ToString("HH:mm:ss")</td>
                                                            <td>@(session.EndTime?.ToString("HH:mm:ss") ?? "进行中")</td>
                                                            <td>
                                                                <span class="badge @(session.IsActive ? "bg-success" : "bg-secondary")">
                                                                    @(session.IsActive ? "进行中" : "已结束")
                                                                </span>
                                                            </td>
                                                            <td>
                                                                @if (session.InterventionTime.HasValue)
                                                                {
                                                                    <div>
                                                                        <span class="badge bg-warning">已接入</span>
                                                                        <small class="text-muted d-block">@session.InterventionReason</small>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-secondary">仅监听</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info">
                                            <i class="bi bi-info-circle me-2"></i>无监控会话记录
                                        </div>
                                    }

                                    <!-- 播放控制 -->
                                    <div class="card-header bg-dark text-light">
                                        <h5 class="mb-0">
                                            <i class="bi bi-play-circle me-2"></i>播放控制
                                            <span class="badge bg-warning float-end">@log.PlaybackControls.Count 条</span>
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        @if (log.PlaybackControls.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-dark table-striped">
                                                    <thead>
                                                        <tr>
                                                            <th>播放状态</th>
                                                            <th>创建时间</th>
                                                            <th>最后更新</th>
                                                            <th>暂停时间</th>
                                                            <th>恢复时间</th>
                                                            <th>操作</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var control in log.PlaybackControls)
                                                        {
                                                            <tr>
                                                                <td>
                                                                    <span class="badge bg-@(control.PlaybackState switch {
                                                                        AI.Caller.Phone.Entities.PlaybackState.NotStarted => "secondary",
                                                                        AI.Caller.Phone.Entities.PlaybackState.Playing => "success",
                                                                        AI.Caller.Phone.Entities.PlaybackState.Paused => "warning",
                                                                        AI.Caller.Phone.Entities.PlaybackState.Interrupted => "danger",
                                                                        AI.Caller.Phone.Entities.PlaybackState.Completed => "info",
                                                                        AI.Caller.Phone.Entities.PlaybackState.Failed => "danger",
                                                                        _ => "secondary"
                                                                    })">
                                                                        @(control.PlaybackState switch {
                                                                            AI.Caller.Phone.Entities.PlaybackState.NotStarted => "未开始",
                                                                            AI.Caller.Phone.Entities.PlaybackState.Playing => "播放中",
                                                                            AI.Caller.Phone.Entities.PlaybackState.Paused => "已暂停",
                                                                            AI.Caller.Phone.Entities.PlaybackState.Interrupted => "已中断",
                                                                            AI.Caller.Phone.Entities.PlaybackState.Completed => "已完成",
                                                                            AI.Caller.Phone.Entities.PlaybackState.Failed => "失败",
                                                                            _ => "未知"
                                                                        })
                                                                    </span>
                                                                </td>
                                                                <td>@control.CreatedAt.ToString("HH:mm:ss")</td>
                                                                <td>@control.UpdatedAt.ToString("HH:mm:ss")</td>
                                                                <td>@(control.PausedAt?.ToString("HH:mm:ss") ?? "-")</td>
                                                                <td>@(control.ResumedAt?.ToString("HH:mm:ss") ?? "-")</td>
                                                                <td>
                                                                    <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#playback-details-@control.Id">
                                                                        <i class="bi bi-chevron-down"></i> 详情
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td colspan="6" class="p-0">
                                                                    <div class="collapse" id="playback-details-@control.Id">
                                                                        <div class="card border-top-0 bg-dark">
                                                                            <div class="card-body">
                                                                                <div class="row">
                                                                                    <div class="col-md-6">
                                                                                        <h6>片段信息</h6>
                                                                                        <p><strong>当前片段ID:</strong> @(control.CurrentSegmentId?.ToString() ?? "无")</p>
                                                                                        <p><strong>最后接入片段ID:</strong> @(control.LastInterventionSegmentId?.ToString() ?? "无")</p>
                                                                                    </div>
                                                                                    <div class="col-md-6">
                                                                                        <h6>跳过的片段</h6>
                                                                                        @if (!string.IsNullOrEmpty(control.SkippedSegments))
                                                                                        {
                                                                                            <p>@control.SkippedSegments</p>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <p class="text-muted">无跳过片段</p>
                                                                                        }
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-info">
                                                <i class="bi bi-info-circle me-2"></i>无播放控制记录
                                            </div>
                                        }
                                </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>