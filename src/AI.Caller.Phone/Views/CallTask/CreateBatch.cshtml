@{
    ViewData["Title"] = "创建批量呼叫任务";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="CreateBatch" enctype="multipart/form-data" method="post">
                <div class="form-group mb-3">
                    <label for="jobName" class="control-label">任务名称</label>
                    <input id="jobName" name="jobName" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label for="ttsTemplateId" class="control-label">TTS模板</label>
                    <select id="ttsTemplateId" name="ttsTemplateId" class="form-control" asp-items="ViewBag.TtsTemplateId">
                        <option value="">-- 请选择模板 --</option>
                    </select>
                </div>
                
                <div class="form-group mb-3">
                    <label class="control-label">线路选择</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="autoSelectLine" name="autoSelectLine" checked>
                        <label class="form-check-label" for="autoSelectLine">
                            自动选择线路
                        </label>
                    </div>
                    <div class="form-group" id="lineSelectionGroup" style="display: none;">
                        <label for="selectedLineId" class="control-label">选择线路</label>
                        <select id="selectedLineId" name="selectedLineId" class="form-control">
                            <option value="">请选择线路</option>
                        </select>
                        <div class="form-text">选择用于批量呼叫的SIP线路。如果不选择，系统将自动选择最优线路。</div>
                    </div>
                </div>
            
                <div class="form-group mb-3">
                    <a id="downloadTemplateBtn" class="btn btn-info disabled" href="#">下载数据模板</a>
                    <small class="form-text text-muted">请先选择一个TTS模板，然后下载对应的数据模板文件。</small>
                </div>

                <div class="form-group mb-3">
                    <label for="file" class="control-label">上传数据文件</label>
                    <input type="file" id="file" name="file" class="form-control" />
                </div>

                <div class="form-group">
                    <input type="submit" value="创建任务" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div>
        <a asp-action="Index">返回列表</a>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // 加载线路列表
            loadAvailableLines();
            
            $('#ttsTemplateId').change(function () {
                var templateId = $(this).val();
                var downloadBtn = $('#downloadTemplateBtn');

                if (templateId) {
                    downloadBtn.removeClass('disabled');
                    downloadBtn.attr('href', '/api/templates/' + templateId + '/excel-template');
                } else {
                    downloadBtn.addClass('disabled');
                    downloadBtn.attr('href', '#');
                }
            });
            
            // 自动选择复选框变化事件
            $('#autoSelectLine').change(function() {
                var autoSelect = $(this).is(':checked');
                $('#lineSelectionGroup').toggle(!autoSelect);
            });
        });
        
        // 加载可用线路
        function loadAvailableLines() {
            $.get('/api/SipLine', function(lines) {
                var lineSelect = $('#selectedLineId');
                lineSelect.empty();
                lineSelect.append('<option value="">请选择线路</option>');
                
                lines.forEach(function(line) {
                    if (line.isActive) {
                        lineSelect.append('<option value="' + line.id + '">' + 
                            line.name + ' (' + (line.region || '未知区域') + ') - ' + 
                            (line.description || '无描述') + '</option>');
                    }
                });
            }).fail(function() {
                console.error('加载线路列表失败');
            });
        }
    </script>
}