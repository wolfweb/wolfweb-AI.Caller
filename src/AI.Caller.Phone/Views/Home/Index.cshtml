@using AI.Caller.Phone.Entities
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model IEnumerable<Contact>

@{
    ViewData["Title"] = "Phone";
}

<div class="container mt-4">
    <div class="row g-4">
        <!-- 左侧通讯录 -->
        <div class="col-lg-4">
            <div class="card modern-card hover-lift">
                <div class="card-header">
                    <h5 class="mb-0 d-flex align-items-center">
                        <div class="icon-wrapper me-3">
                            <i class="bi bi-person-lines-fill"></i>
                        </div>
                        通讯录
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="contactsList">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var contact in Model)
                            {
                                <button type="button" class="list-group-item list-group-item-action contact-item" 
                                        data-name="@contact.Name" data-phone="@contact.PhoneNumber">
                                    <div class="d-flex justify-content-between align-items-center gap-1">
                                        <div>
                                            <i class="bi bi-person-circle text-primary me-2"></i>
                                            <span class="contact-name">@contact.Name</span>
                                        </div>
                                        <span class="badge bg-light text-dark">@contact.PhoneNumber</span>
                                    </div>
                                </button>
                            }
                        }
                        else
                        {
                            <div class="list-group-item text-center py-5 border-0">
                                <div class="empty-state">
                                    <div class="empty-icon mb-3">
                                        <i class="bi bi-person-plus-fill"></i>
                                    </div>
                                    <h6 class="text-muted mb-3">暂无联系人</h6>
                                    <p class="text-muted small mb-3">添加联系人后即可快速拨打电话</p>
                                    <a asp-controller="Account" asp-action="AddContact" class="btn btn-primary btn-sm">
                                        <i class="bi bi-plus-circle me-1"></i> 添加联系人
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer text-center">
                    <a asp-controller="Account" asp-action="ManageContacts" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-gear"></i> 管理通讯录
                    </a>
                </div>
            </div>
        </div>

        <!-- 右侧拨号器 -->
        <div class="col-lg-8">
            <div class="card modern-card hover-lift">
                <div class="card-header">
                    <h5 class="mb-0 d-flex align-items-center">
                        <div class="icon-wrapper me-3">
                            <i class="bi bi-telephone"></i>
                        </div>
                        智能拨号器
                    </h5>
                </div>
                <div class="card-body">
                    <!-- 音频元素 -->
                    <audio id="remoteAudio" autoplay class="d-none"></audio>
                    
                    <!-- 显示当前状态 -->
                    <div class="alert mb-4" id="statusAlert">
                        <span id="status">未连接</span>
                    </div>
                    
                    <!-- 录音状态指示器 -->
                    <div class="alert alert-success mb-4" id="recordingStatusAlert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-record-circle-fill text-success me-2" id="recordingIcon"></i>
                            <span id="recordingStatus">录音状态</span>
                            <span class="badge bg-success ms-auto" id="recordingTimer">待机中</span>
                        </div>
                    </div>
                    
                    <!-- 输入框和拨号按钮 -->
                    <div class="input-group mb-4">
                        <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                        <input type="text" id="destination" class="form-control form-control-lg input-glow" 
                               placeholder="输入电话号码或选择联系人" />
                        <button id="callButton" class="btn btn-success btn-neon">
                            <i class="bi bi-telephone-fill"></i> 拨打
                        </button>
                        <button id="answerButton" class="btn btn-primary btn-neon d-none">
                            <i class="bi bi-telephone-inbound-fill"></i> 接听
                        </button>
                        <button id="hangupButton" class="btn btn-danger btn-neon d-none">
                            <i class="bi bi-telephone-x-fill"></i> 挂断
                        </button>
                        @if (User.HasClaim("isAdmin", "True")) {
                            <button id="pauseRecordingButton" class="btn btn-warning d-none">
                                <i class="bi bi-pause-circle"></i> 暂停录音
                            </button>
                            <button id="resumeRecordingButton" class="btn btn-success d-none">
                                <i class="bi bi-play-circle"></i> 恢复录音
                            </button>
                        }
                    </div>
                    
                    <!-- 线路选择 -->
                    <div id="lineSelectorContainer"></div>
                    
                    <!-- 拨号盘 -->
                    <div class="dialpad dialpad-container mb-3">
                        <div class="dtmf-status-indicator mb-2 d-none" id="dtmfStatusIndicator">
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-soundwave"></i>
                                <span id="dtmfStatusText">通话中 - 点击按键发送DTMF音频</span>
                            </div>
                        </div>
                        
                        <div class="dtmf-input-display mb-3 d-none" id="dtmfInputDisplay">
                            <div class="card">
                                <div class="card-header py-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="bi bi-keyboard"></i> 已输入的按键
                                        </small>
                                        <div>
                                            <button class="btn btn-sm btn-outline-secondary me-1" id="dtmfClearBtn" title="清空显示（已发送的信号无法撤回）">
                                                <i class="bi bi-eraser"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary" id="dtmfToggleVisibility" title="显示/隐藏内容">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body py-2">
                                    <div class="dtmf-input-content">
                                        <div class="input-group">
                                            <span class="input-group-text">
                                                <i class="bi bi-hash"></i>
                                            </span>
                                            <input type="text" class="form-control" id="dtmfInputField" 
                                                   readonly placeholder="按键输入将显示在这里..." 
                                                   style="font-family: 'Courier New', monospace; letter-spacing: 2px; font-size: 1.1rem; background-color: #f8f9fa;">
                                            <button class="btn btn-outline-danger" id="dtmfBackspaceBtn" title="删除显示字符（已发送的信号无法撤回）">
                                                <i class="bi bi-backspace"></i>
                                            </button>
                                        </div>
                                        <div class="mt-2">
                                            <small class="text-muted">
                                                已输入 <span id="dtmfInputCount">0</span> 个字符
                                            </small>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row g-2 mb-2">
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="1">1</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="2">2</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="3">3</button></div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="4">4</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="5">5</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="6">6</button></div>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="7">7</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="8">8</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="9">9</button></div>
                        </div>
                        <div class="row g-2">
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="*">*</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="0">0</button></div>
                            <div class="col-4"><button class="btn btn-light w-100 keypad-btn dialpad-btn-tech" data-key="#">#</button></div>
                        </div>
                    </div>
                    
                    <!-- 通话信息 -->
                    <div class="call-info call-info-tech d-none" id="callInfo">
                        <div class="text-center mb-3">
                            <div class="display-1 text-primary">
                                <i class="bi bi-person-circle"></i>
                            </div>
                            <h3 id="callerName">未知联系人</h3>
                            <p id="callerNumber" class="text-muted"></p>
                        </div>
                        <div class="d-flex justify-content-center">
                            <div id="callTimer" class="badge bg-success p-2 fs-6">00:00</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- PhoneApp 命名空间 - 必须最先加载 -->
    <script src="~/js/phone-namespace.js" asp-append-version="true"></script>
    
    <!-- 核心模块 -->
    <script src="~/js/ringtone-manager.js" asp-append-version="true"></script>
    <script src="~/js/ui-integration.js"></script>
    <script src="~/js/error-recovery.js"></script>
    <script src="~/js/hangup-handler.js"></script>
    <script src="~/js/call-state-manager.js"></script>
    <script src="~/js/ui-manager.js"></script>
    <script src="~/js/webrtc-manager.js"></script>
    <script src="~/js/signalr-manager.js"></script>
    <script src="~/js/simple-recording-manager.js"></script>
    <script src="~/js/phone-app.js"></script>
    <script src="~/js/line-selector.js"></script>
    <script>
        // 全局变量初始化
        window.isRecording = false;
        window.isAutoRecording = false;
        window.callTimerInterval = null;
        window.callStartTime = null;
        window.recordingTimerInterval = null;
        window.recordingStartTime = null;

        // 初始化电话应用
        document.addEventListener('DOMContentLoaded', async function() {
            try {
                window.phoneApp = new PhoneApp();
                await window.phoneApp.initialize();
                console.log('电话应用启动成功');
            } catch (error) {
                console.error('电话应用启动失败:', error);
            }
        });

        // 页面卸载时清理资源
        window.addEventListener('beforeunload', () => {
            if (window.phoneApp && window.phoneApp.signalRManager) {
                window.phoneApp.signalRManager.stopHeartbeat();
                console.log('页面卸载，心跳已停止');
            }
        });
    </script>
}