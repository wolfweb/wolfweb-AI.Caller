@model IEnumerable<AI.Caller.Phone.Entities.ScenarioRecording>

@{
    ViewData["Title"] = "场景录音管理";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h2>场景录音管理</h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> 创建场景
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>名称</th>
                        <th>描述</th>
                        <th>片段数量</th>
                        <th>是否启用</th>
                        <th>创建时间</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.Description</td>
                            <td>@item.Segments.Count</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">启用</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">禁用</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> 编辑
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> 详情
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> 删除
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> 暂无场景录音，请点击"创建场景"按钮添加。
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 可以添加一些交互脚本
    </script>
}
